data/hamiltonians/*
!data/hamiltonians/.gitkeep

circuits/transpiled/*
!circuits/transpiled/.gitkeep

results/krylov_matrices/*
!results/krylov_matrices/.gitkeep

results/summaries/*
!results/summaries/.gitkeep

results/hardware_jobs/*
!results/hardware_jobs/.gitkeep
